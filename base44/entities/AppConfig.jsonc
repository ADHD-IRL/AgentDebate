{
  "name": "AppConfig",
  "type": "object",
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "key": {
      "type": "string",
      "description": "Configuration key (e.g. 'llm_model')"
    },
    "value": {
      "type": "string",
      "description": "Configuration value"
    },
    "label": {
      "type": "string",
      "description": "Human-readable label for this config entry"
    }
  },
  "required": [
    "key",
    "value"
  ]
}