{
  "name": "SessionSynthesis",
  "type": "object",
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "consensus_findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "contested_findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "compound_chains": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "blind_spots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority_mitigations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sharpest_insights": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "raw_text": {
      "type": "string",
      "description": "Public URL to uploaded synthesis text file"
    }
  },
  "required": [
    "session_id"
  ]
}