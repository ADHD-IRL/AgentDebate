{
  "name": "Session",
  "type": "object",
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "domain_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "round1",
        "round2",
        "complete"
      ],
      "default": "pending"
    },
    "phase_focus": {
      "type": "string"
    },
    "context_override": {
      "type": "string"
    },
    "agent_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "name"
  ]
}